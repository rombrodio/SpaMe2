# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# supabase
supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Agent skills source-of-truth lives in .agents/skills/ and is committed.
# The 28 per-agent folders below are just symlinks pointing back to .agents/
# and are regenerated by `npx skills experimental_sync -y` from skills-lock.json.
.adal/
.augment/
.bob/
.claude/
.codebuddy/
.commandcode/
.continue/
.cortex/
.crush/
.factory/
.goose/
.iflow/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/
# Top-level `skills/` is also a symlink shortcut into .agents/skills/.
/skills/
