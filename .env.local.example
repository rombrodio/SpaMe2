# ─────────────────────────────────────────────────────────────
# SpaMe — env template. Copy to .env.local and fill in the blanks.
#
# Everything under "Phase 4 — Payments" defaults to mock providers
# when the real values are missing, so local dev works out of the
# box after setting only ORDER_TOKEN_SECRET + the Supabase values
# below.
# ─────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Supabase anon/publishable key. Either variable name is accepted;
# NEXT_PUBLIC_SUPABASE_ANON_KEY takes precedence if both are set.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-default-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
# REQUIRED in both dev + prod (Phase 4.6): these drive every outbound
# redirect URL — password-reset emails, therapist invites, assignment
# deep-links, payment return URLs. Missing in prod = hard failure on
# those code paths (no silent localhost fallback). Set both the server
# and the NEXT_PUBLIC variants to the same origin.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Phase 4 — Payments ──────────────────────────────────────

# CRITICAL: signs the /order/<token> finalization JWTs. Required.
# Generate: openssl rand -base64 48
ORDER_TOKEN_SECRET=

# Base URL CardCom returns to after the hosted-page iframe submits.
# In dev leave as localhost; in production use your live domain.
CARDCOM_RETURN_URL_BASE=http://localhost:3000

# Provider selection. Default is "mock" — the in-memory providers
# under src/lib/payments/mock.ts. Set to "real" once the real-provider
# credentials below are filled in.
PAYMENTS_CARDCOM_PROVIDER=mock
PAYMENTS_DTS_PROVIDER=mock
PAYMENTS_VPAY_PROVIDER=mock

# ─── CardCom (only used when PAYMENTS_CARDCOM_PROVIDER=real) ─

CARDCOM_BASE_URL=https://secure.cardcom.solutions
CARDCOM_TERMINAL_NUMBER=
CARDCOM_API_USERNAME=
CARDCOM_API_PASSWORD=
# Shared secret we place in the webhook URL path
# (/api/webhooks/cardcom/<secret>). Any 32+ character random string.
CARDCOM_WEBHOOK_SHARED_SECRET=

# ─── DTS benefit vouchers (only when PAYMENTS_DTS_PROVIDER=real) ─

DTS_FOREIGN_TERMINAL=
DTS_BASE_URL=https://dtsposservicesv2.dts.co.il/DtsPosServices.asmx

# ─── VPay vouchers (only when PAYMENTS_VPAY_PROVIDER=real) ──

# VPay requires IP allowlist or client-cert mTLS. In production we
# route through a Fly.io proxy (Phase 4.5 — services/vpay-proxy/).
# Point VPAY_PROXY_URL at that deployment; HMAC_SECRET is shared
# between main app and proxy.
VPAY_PROXY_URL=
VPAY_PROXY_HMAC_SECRET=

# ─── Twilio (SMS; used by /order/[token]/success) ──────────

# Without these set, SMS sends fail silently with a config_error
# reason and the booking still confirms. See
# src/lib/messaging/twilio.ts for the exact behaviour.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Exactly one of these must be set when SMS is enabled:
#  - TWILIO_MESSAGING_SERVICE_SID (preferred; Twilio best practice)
#  - TWILIO_SMS_FROM (bare E.164 number or alphanumeric sender ID)
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SMS_FROM=

# ─── Vercel Cron ───────────────────────────────────────────

# Vercel Cron signs requests with Authorization: Bearer <CRON_SECRET>.
# Required in production. In dev, missing secret lets you curl the
# cron endpoint directly for testing.
CRON_SECRET=

# ─── Phase 5 — Deferred therapist assignment (WhatsApp notifications) ─

# WhatsApp via Twilio Business API. Used alongside SMS for every
# manager + therapist assignment notification. Without these set, the
# notification dispatcher (src/lib/messaging/notify.ts) falls back to
# SMS-only and logs a warning — the app still works, it just can't
# deliver via WhatsApp.

# E.164 number Twilio approved as your WhatsApp sender.
# TWILIO_WHATSAPP_FROM=whatsapp:+14155551234

# Meta-approved Content Template SIDs (start with HX...). Each template
# needs its own approval request in the Twilio console; the variable
# order is documented in src/lib/messaging/notify.ts.
# TWILIO_WA_TEMPLATE_MANAGER_ALERT=
# TWILIO_WA_TEMPLATE_MANAGER_REASSIGN=
# TWILIO_WA_TEMPLATE_THERAPIST_REQUEST=
# TWILIO_WA_TEMPLATE_MANAGER_ESCALATION=

# ─── Phase 6+ (deferred; documented so future branches can add) ─

# WhatsApp conversational channel (inbound webhook)
# TWILIO_WHATSAPP_WEBHOOK_SECRET=

# AI Chatbot (Phase 6)
# ANTHROPIC_API_KEY=

# ─── MCP servers (Cursor-only — NOT required to boot the app) ─
#
# These environment variables are read by .cursor/mcp.json. They do NOT
# affect `npm run dev`, `npm run build`, CI, or production. Leave unset
# if you do not want the agent to hit dev DB / GitHub / browser.
#
# Populate only in your shell profile (~/.zshrc or ~/.bash_profile), NOT
# in .env.local — MCP is an agent-side feature, not a server-side one.
#
# HARD RULE: SUPABASE_DEV_ACCESS_TOKEN is a scoped personal access token
# from https://supabase.com/dashboard/account/tokens, NEVER the
# SUPABASE_SERVICE_ROLE_KEY. Service-role bypasses RLS and would expose
# every row in every project to the agent. Rule 90-mcp-safety.mdc blocks
# the violation at review; scan-prompt.sh blocks it in prompts.
#
# SUPABASE_DEV_PROJECT_REF=<dev-project-ref>         # dev project only — never prod
# SUPABASE_DEV_ACCESS_TOKEN=<scoped-supabase-pat>    # NOT service-role
# GITHUB_MCP_PAT=<fine-grained-gh-pat>               # contents:write, pull_requests:write, issues:write; this repo only
