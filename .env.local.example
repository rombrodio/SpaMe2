# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Supabase anon/publishable key. Either variable name is accepted;
# NEXT_PUBLIC_SUPABASE_ANON_KEY takes precedence if both are set.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-default-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
APP_URL=http://localhost:3000

# Payment provider (Phase 4)
# PAYMENT_PROVIDER=mock
# CARDCOM_TERMINAL_NUMBER=
# CARDCOM_API_NAME=
# CARDCOM_WEBHOOK_SECRET=

# WhatsApp (Phase 6)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=

# AI Chatbot (Phase 6)
# ANTHROPIC_API_KEY=
