# ─────────────────────────────────────────────────────────────
# SpaMe — env template. Copy to .env.local and fill in the blanks.
#
# Everything under "Phase 4 — Payments" defaults to mock providers
# when the real values are missing, so local dev works out of the
# box after setting only ORDER_TOKEN_SECRET + the Supabase values
# below.
# ─────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Supabase anon/publishable key. Either variable name is accepted;
# NEXT_PUBLIC_SUPABASE_ANON_KEY takes precedence if both are set.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-default-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
APP_URL=http://localhost:3000

# ─── Phase 4 — Payments ──────────────────────────────────────

# CRITICAL: signs the /order/<token> finalization JWTs. Required.
# Generate: openssl rand -base64 48
ORDER_TOKEN_SECRET=

# Base URL CardCom returns to after the hosted-page iframe submits.
# In dev leave as localhost; in production use your live domain.
CARDCOM_RETURN_URL_BASE=http://localhost:3000

# Provider selection. Default is "mock" — the in-memory providers
# under src/lib/payments/mock.ts. Set to "real" once the real-provider
# credentials below are filled in.
PAYMENTS_CARDCOM_PROVIDER=mock
PAYMENTS_DTS_PROVIDER=mock
PAYMENTS_VPAY_PROVIDER=mock

# ─── CardCom (only used when PAYMENTS_CARDCOM_PROVIDER=real) ─

CARDCOM_BASE_URL=https://secure.cardcom.solutions
CARDCOM_TERMINAL_NUMBER=
CARDCOM_API_USERNAME=
CARDCOM_API_PASSWORD=
# Shared secret we place in the webhook URL path
# (/api/webhooks/cardcom/<secret>). Any 32+ character random string.
CARDCOM_WEBHOOK_SHARED_SECRET=

# ─── DTS benefit vouchers (only when PAYMENTS_DTS_PROVIDER=real) ─

DTS_FOREIGN_TERMINAL=
DTS_BASE_URL=https://dtsposservicesv2.dts.co.il/DtsPosServices.asmx

# ─── VPay vouchers (only when PAYMENTS_VPAY_PROVIDER=real) ──

# VPay requires IP allowlist or client-cert mTLS. In production we
# route through a Fly.io proxy (Phase 4.5 — services/vpay-proxy/).
# Point VPAY_PROXY_URL at that deployment; HMAC_SECRET is shared
# between main app and proxy.
VPAY_PROXY_URL=
VPAY_PROXY_HMAC_SECRET=

# ─── Twilio (SMS; used by /order/[token]/success) ──────────

# Without these set, SMS sends fail silently with a config_error
# reason and the booking still confirms. See
# src/lib/messaging/twilio.ts for the exact behaviour.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Exactly one of these must be set when SMS is enabled:
#  - TWILIO_MESSAGING_SERVICE_SID (preferred; Twilio best practice)
#  - TWILIO_SMS_FROM (bare E.164 number or alphanumeric sender ID)
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SMS_FROM=

# ─── Vercel Cron ───────────────────────────────────────────

# Vercel Cron signs requests with Authorization: Bearer <CRON_SECRET>.
# Required in production. In dev, missing secret lets you curl the
# cron endpoint directly for testing.
CRON_SECRET=

# ─── Phase 5+ (deferred; documented so future branches can add) ─

# WhatsApp via Twilio Business API
# TWILIO_WHATSAPP_FROM=whatsapp:+14155551234
# TWILIO_WHATSAPP_WEBHOOK_SECRET=

# AI Chatbot (Phase 6)
# ANTHROPIC_API_KEY=
